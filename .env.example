# DTM AI — environment template.  Copy to .env and `chmod 600 .env`.
# Invariant I-3: no plaintext secrets in git. .env is gitignored; boot refuses a
# group/world-readable .env. Secrets are only ever surfaced as sha256[:7] fingerprints.

# ── Core ────────────────────────────────────────────────────────────────────
DTM_ENV=dev                       # dev | prod
DTM_DB_URL=sqlite:///dtm_ai.db    # dev: sqlite file.  prod: postgresql://user:pass@host/dtm_ai
DTM_SESSION_TTL_MIN=720           # session lifetime (minutes); sessions rotate on use

# ── Model router (D-3 local-first) ──────────────────────────────────────────
DTM_LOCAL_MODEL=llama3.1          # default local Ollama model for client-data tasks
DTM_OLLAMA_URL=http://localhost:11434
DTM_ALLOW_CLOUD=0                 # global kill switch for cloud providers (0 = local only)
ANTHROPIC_API_KEY=                # optional; only used when a task is explicitly allowed to use cloud
OPENAI_API_KEY=                   # optional

# ── Integrations: GREEN today (Phase L) ─────────────────────────────────────
# Kaseya VSA (read-only bridge account)
KASEYA_BASE_URL=
KASEYA_USER=
KASEYA_PASSWORD=
KASEYA_TOKEN=                     # optional static bearer; else user/password -> /auth

# Cylance Console
CYLANCE_TENANT_ID=
CYLANCE_APP_ID=
CYLANCE_APP_SECRET=
CYLANCE_REGION=us                 # us | euc1 | au | ...

# Huntress
HUNTRESS_API_KEY=
HUNTRESS_API_SECRET=

# ── Integrations: later (Phase 3 stubs) ─────────────────────────────────────
# MS365_TENANT_ID=  MS365_CLIENT_ID=  MS365_CLIENT_SECRET=
