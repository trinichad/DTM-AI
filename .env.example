# MSP AI — environment template.  Copy to .env and `chmod 600 .env`.
# Invariant I-3: no plaintext secrets in git. .env is gitignored; boot refuses a
# group/world-readable .env. Secrets are only ever surfaced as sha256[:7] fingerprints.

# ── Core ────────────────────────────────────────────────────────────────────
MSPAI_ENV=dev                       # dev | prod
MSPAI_DB_URL=sqlite:///msp_ai.db    # dev: sqlite file.  prod: postgresql://user:pass@host/msp_ai
MSPAI_SESSION_TTL_MIN=720           # session lifetime (minutes); sessions rotate on use

# ── Model router (D-3 local-first) ──────────────────────────────────────────
MSPAI_LOCAL_MODEL=llama3.1          # default local Ollama model for client-data tasks
MSPAI_OLLAMA_URL=http://localhost:11434
MSPAI_ALLOW_CLOUD=1                 # 1 = cloud models selectable once their key is added; 0 = hard local-only
# Cloud keys are normally entered in the dashboard (Integrations -> AI models -> Manage key),
# stored securely in secrets.local. These .env entries are an alternative.
ANTHROPIC_API_KEY=                # add to enable Claude models in the chat selector
OPENAI_API_KEY=                   # add to enable OpenAI models

# ── Integrations: GREEN today (Phase L) ─────────────────────────────────────
# Kaseya VSA (read-only bridge account)
KASEYA_BASE_URL=
KASEYA_USER=
KASEYA_PASSWORD=
KASEYA_TOKEN=                     # optional static bearer; else user/password -> /auth

# Cylance Console
CYLANCE_TENANT_ID=
CYLANCE_APP_ID=
CYLANCE_APP_SECRET=
CYLANCE_REGION=us                 # us | euc1 | au | ...

# Huntress
HUNTRESS_API_KEY=
HUNTRESS_API_SECRET=

# ── Integrations: later (Phase 3 stubs) ─────────────────────────────────────
# MS365_TENANT_ID=  MS365_CLIENT_ID=  MS365_CLIENT_SECRET=
